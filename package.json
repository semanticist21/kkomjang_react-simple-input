{
  "name": "@kkoms/react-simple-input",
  "private": false,
  "version": "0.2.8",
  "description": "declarative simplified input/checkbox handlers for react.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "./dist"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint . --max-warnings=0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      },
      "default": "./dist/index.mjs"
    }
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/react": "19.2.7",
    "eslint": "9.39.3",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "globals": "16.5.0",
    "react": "19.2.3",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.50.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0 <20.0.0"
  },
  "pnpm": {
    "overrides": {
      "@babel/parser": "7.28.5",
      "@babel/traverse": "7.28.5",
      "@babel/types": "7.28.5",
      "minimatch": "3.1.2",
      "rollup": "4.53.5"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "keywords": [
    "react",
    "input",
    "checkbox",
    "handler",
    "simple"
  ],
  "bugs": {
    "url": "https://github.com/semanticist21/kkom-simple-input/issues",
    "email": "semanticist0@gmail.com"
  },
  "license": "MIT",
  "author": {
    "name": "jwp",
    "email": "semanticist0@gmail.com",
    "url": "https://github.com/semanticist21"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/semanticist21/kkom-simple-input"
  }
}
